CLICKHOUSE_HOST=localhost
CLICKHOUSE_PORT=8123
CLICKHOUSE_DATABASE=blotter
CLICKHOUSE_USERNAME=default
CLICKHOUSE_PASSWORD=

GOOGLE_GEOCODING_API_KEY=your_google_maps_api_key
GOOGLE_NLP_API_KEY=your_google_nlp_api_key

TRANSCRIPTION_MODEL_SIZE=large-v3
TRANSCRIPTION_DEVICE=cuda
TRANSCRIPTION_COMPUTE_TYPE=float16

DATA_DIR=data

# Stream capture
GCS_BUCKET=blotter-audio
GCS_PROJECT=your-gcp-project
REDIS_HOST=localhost
REDIS_PORT=6379
STREAM_SEGMENT_TIME=300
STREAM_OVERLAP_SECONDS=5
STREAM_AD_SKIP_SECONDS=35
STREAM_CHUNK_DIR=/tmp/blotter
STREAM_FEEDS=20296:LAPD South Bureau,33623:LAPD West Bureau,26569:LAPD Valley Bureau,40488:LAPD Hotshot,25187:LASD Multi-Dispatch,24051:Long Beach PD

# Region (LA County defaults)
REGION_NAME=Los Angeles
REGION_STATE=CA
