:8888 {
	header {
		X-Content-Type-Options nosniff
		X-Frame-Options DENY
		Referrer-Policy strict-origin-when-cross-origin
		-Server
	}

	handle /api/query* {
		uri strip_prefix /api/query
		reverse_proxy clickhouse:8123 {
			header_up X-ClickHouse-User blotter_readonly
			header_up X-ClickHouse-Key {$CLICKHOUSE_READONLY_PASSWORD:readonly}
		}
	}

	handle {
		root * /srv
		file_server
		try_files {path} /index.html
	}
}
